{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "noImplicitAny": false,

    "strict": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "rootDir": ".",
    "outDir": "dist",

   "paths": {
      "@/*": ["./src/*"]
   }

  },
  "include": ["src/**/*","knexfile.js"],
  "exclude": ["node_modules"]
}
